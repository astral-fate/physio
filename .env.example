# NVIDIA NIM (recommended) — https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
FITKG_CHAT_MODEL=qwen/qwen3-next-80b-a3b-instruct
FITKG_LLM_TEMPERATURE=0.6
FITKG_LLM_TOP_P=0.7
FITKG_LLM_MAX_TOKENS=1024
# FITKG_LLM_STREAM=true

# Vercel deployment: add the same keys in Project → Settings → Environment Variables.
# LLM chat needs Pro plan (60s timeout) or set FITKG_LLM_MAX_TOKENS=512 on Hobby (10s).

# Or OpenAI-compatible (optional alternative)
# OPENAI_API_KEY=
# FITKG_CHAT_MODEL=gpt-4o-mini
